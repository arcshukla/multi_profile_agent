{
  "donation_received": {
    "name": "Donation Received",
    "description": "Sent to the profile owner when an admin confirms receipt of their voluntary donation to the platform. Available placeholders: {owner_name}, {amount}, {donation_id}, {confirmed_at}, {support_email}, {owner_url}.",
    "subject": "Thank you for your donation \u2014 \u20b9{amount} received!",
    "body_text": "Hi {owner_name},\n\nThank you so much for your generous contribution to the platform!\n\nWe have confirmed receipt of your voluntary donation:\n\nAmount    : \u20b9{amount}\nReference : {donation_id}\nConfirmed : {confirmed_at}\n\nYour support helps us keep the platform running and improving. We truly appreciate it.\n\nManage your profile: {owner_url}\n\nIf you have any questions, reach us at {support_email}.\n\n\u2014 AI Profile Platform",
    "body_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"></head>\n<body style=\"margin:0;padding:0;background:#f4f4f5;font-family:sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f4f5;padding:32px 0;\">\n    <tr><td align=\"center\">\n      <table width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e4e4e7;\">\n\n        <!-- Header -->\n        <tr>\n          <td style=\"background:#4f46e5;padding:24px 32px;\">\n            <p style=\"margin:0;font-size:18px;font-weight:600;color:#ffffff;\">AI Profile Platform</p>\n          </td>\n        </tr>\n\n        <!-- Body -->\n        <tr>\n          <td style=\"padding:32px;\">\n            <p style=\"margin:0 0 6px;font-size:15px;color:#374151;\">Hi {owner_name},</p>\n            <p style=\"margin:0 0 24px;font-size:14px;color:#6b7280;\">\n              Thank you so much for your generous contribution to the platform! We\u2019ve confirmed receipt of your donation.\n            </p>\n\n            <!-- Donation details block -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n              <tr>\n                <td style=\"background:#f9fafb;border-left:4px solid #4f46e5;border-radius:4px;padding:14px 18px;\">\n                  <p style=\"margin:0;font-size:13px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;\">Donation confirmed</p>\n                  <p style=\"margin:8px 0 0;font-size:22px;font-weight:700;color:#111827;\">\u20b9{amount}</p>\n                </td>\n              </tr>\n            </table>\n\n            <!-- Meta -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-top:20px;border-top:1px solid #f3f4f6;padding-top:16px;\">\n              <tr>\n                <td style=\"font-size:13px;color:#9ca3af;padding-bottom:5px;\">\n                  <strong style=\"color:#374151;\">Reference:</strong>&nbsp;<span style=\"font-family:monospace;\">{donation_id}</span>\n                </td>\n              </tr>\n              <tr>\n                <td style=\"font-size:13px;color:#9ca3af;\">\n                  <strong style=\"color:#374151;\">Confirmed on:</strong>&nbsp;{confirmed_at}\n                </td>\n              </tr>\n            </table>\n\n            <!-- Thank-you note -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-top:20px;\">\n              <tr>\n                <td style=\"background:#ecfdf5;border-radius:8px;padding:14px 18px;\">\n                  <p style=\"margin:0;font-size:13px;color:#065f46;\">\n                    <strong>Your support matters!</strong> Every contribution helps us keep the platform free and continuously improving.\n                  </p>\n                </td>\n              </tr>\n            </table>\n\n            <!-- CTA -->\n            <p style=\"margin:28px 0 0;text-align:center;\">\n              <a href=\"{owner_url}\"\n                 style=\"display:inline-block;background:#4f46e5;color:#ffffff;text-decoration:none;\n                        font-size:14px;font-weight:600;padding:10px 24px;border-radius:8px;\">\n                Go to Owner Portal\n              </a>\n            </p>\n          </td>\n        </tr>\n\n        <!-- Footer -->\n        <tr>\n          <td style=\"background:#f9fafb;padding:16px 32px;border-top:1px solid #f3f4f6;\">\n            <p style=\"margin:0;font-size:12px;color:#9ca3af;text-align:center;\">\n              Questions? Contact us at <a href=\"mailto:{support_email}\" style=\"color:#6366f1;\">{support_email}</a>\n            </p>\n          </td>\n        </tr>\n\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>"
  },
  "unanswered_question": {
    "name": "Unanswered Question",
    "description": "Sent to the profile owner when a visitor asks a question the AI could not answer and the owner has opted in to email notifications. Available placeholders: {owner_name}, {question}, {session_id}, {slug}, {chat_url}, {owner_url}.",
    "subject": "Unanswered question on your AI profile",
    "body_text": "Hi {owner_name},\n\nA visitor asked a question your AI profile could not answer.\n\nQuestion: {question}\n\nSession : {session_id}\nProfile : {slug}\n\nTry your profile: {chat_url}\nManage your profile: {owner_url}\n\nTip: Consider adding content to your documents to cover this topic.\n\n\u2014 AI Profile Platform",
    "body_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"></head>\n<body style=\"margin:0;padding:0;background:#f4f4f5;font-family:sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f4f5;padding:32px 0;\">\n    <tr><td align=\"center\">\n      <table width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e4e4e7;\">\n\n        <!-- Header -->\n        <tr>\n          <td style=\"background:#4f46e5;padding:24px 32px;\">\n            <p style=\"margin:0;font-size:18px;font-weight:600;color:#ffffff;\">AI Profile Platform</p>\n          </td>\n        </tr>\n\n        <!-- Body -->\n        <tr>\n          <td style=\"padding:32px;\">\n            <p style=\"margin:0 0 6px;font-size:15px;color:#374151;\">Hi {owner_name},</p>\n            <p style=\"margin:0 0 24px;font-size:14px;color:#6b7280;\">\n              A visitor asked a question your AI profile couldn't answer.\n            </p>\n\n            <!-- Question block -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n              <tr>\n                <td style=\"background:#f9fafb;border-left:4px solid #4f46e5;border-radius:4px;padding:14px 18px;\">\n                  <p style=\"margin:0;font-size:13px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;\">Question asked</p>\n                  <p style=\"margin:6px 0 0;font-size:15px;color:#111827;\">{question}</p>\n                </td>\n              </tr>\n            </table>\n\n            <!-- Meta -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-top:20px;border-top:1px solid #f3f4f6;padding-top:16px;\">\n              <tr>\n                <td style=\"font-size:13px;color:#9ca3af;padding-bottom:5px;\">\n                  <strong style=\"color:#374151;\">Profile:</strong>&nbsp;{slug}\n                </td>\n              </tr>\n              <tr>\n                <td style=\"font-size:13px;color:#9ca3af;\">\n                  <strong style=\"color:#374151;\">Session:</strong>&nbsp;<span style=\"font-family:monospace;\">{session_id}</span>\n                </td>\n              </tr>\n            </table>\n\n            <!-- Tip -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-top:20px;\">\n              <tr>\n                <td style=\"background:#eff6ff;border-radius:8px;padding:14px 18px;\">\n                  <p style=\"margin:0;font-size:13px;color:#1e40af;\">\n                    <strong>Tip:</strong> Add content to your profile documents to help your AI answer questions like this in future.\n                  </p>\n                </td>\n              </tr>\n            </table>\n\n            <!-- CTAs -->\n            <p style=\"margin:28px 0 0;text-align:center;\">\n              <a href=\"{chat_url}\"\n                 style=\"display:inline-block;background:#4f46e5;color:#ffffff;text-decoration:none;\n                        font-size:14px;font-weight:600;padding:10px 24px;border-radius:8px;margin-right:8px;\">\n                Try Your Profile\n              </a>\n              <a href=\"{owner_url}\"\n                 style=\"display:inline-block;background:#f3f4f6;color:#374151;text-decoration:none;\n                        font-size:14px;font-weight:600;padding:10px 24px;border-radius:8px;\">\n                Owner Portal\n              </a>\n            </p>\n          </td>\n        </tr>\n\n        <!-- Footer -->\n        <tr>\n          <td style=\"background:#f9fafb;padding:16px 32px;border-top:1px solid #f3f4f6;\">\n            <p style=\"margin:0;font-size:12px;color:#9ca3af;text-align:center;\">\n              You received this because you opted in to unanswered-question alerts.<br>\n              Manage your preferences at <a href=\"{owner_url}\" style=\"color:#6366f1;\">owner preferences</a>.\n            </p>\n          </td>\n        </tr>\n\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>"
  }
}
